{
  "expo": {
    "name": "expo-specs",
    "slug": "expo-specs",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expospecs",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.lucaskesselman.expospecs",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera for AR experiences.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c3201e9f-b4f9-4105-9e9e-d92aaf40415a"
      }
    }
  }
}
